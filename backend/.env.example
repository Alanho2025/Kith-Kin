ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOWED_ORIGINS=["http://localhost:5173"]

DEPLOYMENT_MODE=local
LIVE_TRANSPORT=backend_proxy
SESSION_STORE=sqlite
MCP_TRANSPORT=stdio
NOTIFICATION_PROVIDER=stub

DATABASE_URL=sqlite+aiosqlite:///kithkin.db
TEST_DATABASE_URL=sqlite+aiosqlite:///kithkin_test.db

GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GEMINI_API_VERSION=v1alpha
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_LIVE_TRANSLATE_MODEL=gemini-3.5-live-translate-preview
LIVE_TRANSLATION_FALLBACK_ENABLED=false

APP_WS_TOKEN_SECRET=
APP_WS_TOKEN_TTL_SECONDS=60
APP_WS_TOKEN_ISSUER=kithkin-backend
APP_WS_TOKEN_AUDIENCE=kithkin-live-ws
APP_WS_TOKEN_MAX_USES=1
APP_WS_COOKIE_NAME=kk_live_ticket
APP_WS_COOKIE_SAMESITE=strict
APP_WS_COOKIE_SECURE=false

LIVE_SESSION_MAX_SECONDS=840

RAG_MAX_RECORDS=5
RAG_MAX_CONTEXT_CHARS=4000
RAG_TIMEOUT_MS=1500
DRUG_CHECK_TIMEOUT_MS=2500
MEMORY_WRITE_TIMEOUT_MS=3000
NOTIFICATION_TIMEOUT_MS=5000

TRACE_RETENTION_DAYS=30
VISIT_RETENTION_DAYS=30
